# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://houseledger:houseledger@localhost:5433/houseledger"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs from your Stripe dashboard
STRIPE_PRICE_ID_STANDARD="price_..."
STRIPE_PRICE_ID_PREMIUM="price_..."

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── File Storage ──────────────────────────────────────────────────────────────
# Local dev: files stored in /uploads (relative to project root)
# Production: set STORAGE_PROVIDER=s3 and add S3 creds
STORAGE_PROVIDER="local"
